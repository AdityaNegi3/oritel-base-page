# ── Razorpay (public key only — never put your SECRET here) ──────────────────
# Same Key ID from your Razorpay dashboard (starts with rzp_live_ or rzp_test_)
VITE_RAZORPAY_KEY_ID=rzp_live_XXXXXXXXXXXXXXXX

# ── Google Sign-In ────────────────────────────────────────────────────────────
# Same Client ID from Google Cloud Console (must match the backend value)
# Authorized JS origins must include: http://localhost:5173  +  your prod domain
VITE_GOOGLE_CLIENT_ID=XXXXXXXXXX-XXXXXXXXXXXXXXXXXXXX.apps.googleusercontent.com

# ── Backend API URL ───────────────────────────────────────────────────────────
# Leave blank in dev — Vite proxies /api → localhost:3001 automatically
# In Vercel, set this to your deployed backend URL (e.g. https://api.oritel.in)
VITE_API_URL=

# ── Post-payment redirect ─────────────────────────────────────────────────────
# After subscription payment, user is redirected here to complete onboarding
VITE_SAAS_URL=https://app.oritel.in
